#!/usr/bin/env bash

set -euo pipefail

readonly SUBDIRS=(slides assets demo scripts notes)

print_usage() {
  cat <<'USAGE'
Usage: opentalk <init|check> [options]

Commands:
  init    Create a new talk skeleton
  check   Validate existing talk directories

Init options:
  -d DATE     Date in YYYY-MM-DD (default: today)
  -t TITLE    Slug in kebab-case (required)
  -l LANG     Language: en or zh (default: zh)
  -v VENUE    Venue: online or offline (default: online)
  -r ROOT     Root directory (default: talks)

Check options:
  -r ROOT     Root directory (default: talks)

Examples:
  opentalk init -t my-awesome-talk
  opentalk init -t kcd-beijing -d 2025-03-15 -l zh -v offline
  opentalk check
  opentalk check -r talks
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

validate_date() {
  local date="$1"
  if ! date -jf "%Y-%m-%d" "$date" "+%Y-%m-%d" >/dev/null 2>&1; then
    die "invalid date '$date': expected YYYY-MM-DD"
  fi
}

validate_title() {
  local title="$1"
  if [[ ! "$title" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
    die "invalid title '$title': ascii lowercase kebab-case required"
  fi
}

validate_lang() {
  local lang="$1"
  if [[ "$lang" != "en" && "$lang" != "zh" ]]; then
    die "invalid lang '$lang': en or zh"
  fi
}

validate_venue() {
  local venue="$1"
  if [[ "$venue" != "online" && "$venue" != "offline" ]]; then
    die "invalid venue '$venue': online or offline"
  fi
}

validate_dir_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9]+(-[a-z0-9]+)*-(en|zh)-(online|offline)$ ]]; then
    return 1
  fi
  return 0
}

cmd_init() {
  local date
  local title=""
  local lang="zh"
  local venue="online"
  local root="talks"
  date="$(date +%Y-%m-%d)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) print_usage; exit 0 ;;
      -d) date="$2"; shift 2 ;;
      -t) title="$2"; shift 2 ;;
      -l) lang="$2"; shift 2 ;;
      -v) venue="$2"; shift 2 ;;
      -r) root="$2"; shift 2 ;;
      *)  die "unknown flag: $1" ;;
    esac
  done

  if [[ -z "$title" ]]; then
    die "missing required flag: -t TITLE"
  fi

  validate_date "$date"
  validate_title "$title"
  validate_lang "$lang"
  validate_venue "$venue"

  local name="${date}-${title}-${lang}-${venue}"
  local target="${root}/${name}"

  mkdir -p "$target"
  touch "$target/outline.md"
  for sub in "${SUBDIRS[@]}"; do
    mkdir -p "$target/$sub"
  done

  echo "$target"
}

cmd_check() {
  local root="talks"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) print_usage; exit 0 ;;
      -r) root="$2"; shift 2 ;;
      *)  die "unknown flag: $1" ;;
    esac
  done

  if [[ ! -d "$root" ]]; then
    echo "No talks directory: $root"
    exit 0
  fi

  local has_error=false
  for dir in "$root"/*/; do
    [[ -d "$dir" ]] || continue
    local base
    base="$(basename "$dir")"

    if ! validate_dir_name "$base"; then
      continue
    fi

    if [[ ! -f "$dir/outline.md" ]]; then
      echo "ERROR $base: missing outline.md"
      has_error=true
      continue
    fi

    echo "OK $base"
  done

  if [[ "$has_error" == true ]]; then
    exit 1
  fi
}

if [[ $# -lt 1 ]]; then
  print_usage
  exit 1
fi

case "$1" in
  init)  shift; cmd_init "$@" ;;
  check) shift; cmd_check "$@" ;;
  help|-h|--help) print_usage ;;
  *)     print_usage; exit 1 ;;
esac
